{
  "npmScope": "dev",
  "affected": {
    "defaultBase": "main"
  },
  "implicitDependencies": {
    "workspace.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    },
    "tsconfig.base.json": "*",
    "tslint.json": "*",
    ".eslintrc.json": "*",
    "nx.json": "*"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "lint", "test", "e2e"]
      }
    }
  },
  "projects": {
    "kanban": {
      "tags": ["type:app"]
    },
    "kanban-e2e": {
      "tags": [],
      "implicitDependencies": ["kanban"]
    },
    "p2p-server": {
      "tags": ["side:server"]
    },
    "peer-server": {
      "tags": ["side:server"]
    },
    "peer-ng-client": {
      "tags": []
    },
    "peer-client": {
      "tags": []
    },
    "gui-seek": {
      "tags": []
    },
    "gui-seek-e2e": {
      "tags": [],
      "implicitDependencies": ["gui-seek"]
    }
  }
}
